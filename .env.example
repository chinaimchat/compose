# 基础配置
CONTAINER_NAME=my
# 服务器公网主 IP。示例使用文档保留 IP，部署时改成你的服务器 IP。
EXTERNAL_IP=203.0.113.10

# 对外域名统一配置：以后换站点优先改这里
PUBLIC_SCHEME=http
PUBLIC_DOMAIN=example.com
PUBLIC_WEB_HOST=www.example.com
PUBLIC_IM_HOST=im.example.com
PUBLIC_MANAGER_HOST=admin.example.com

# 端口（官方默认）
TS_WEB_PORT=82
TS_MANAGEMENT_PORT=83
# 容器内 web/manager 反代到后端的内部地址（一般无需改）
INTERNAL_API_URL=http://server:8090/
# 容器内 Nginx 的 server_name（一般无需改，跟随 PUBLIC_* 自动展开）
WEB_SERVER_NAME=web.${PUBLIC_DOMAIN} ${PUBLIC_WEB_HOST} ${PUBLIC_DOMAIN} localhost
MANAGER_SERVER_NAME=${PUBLIC_MANAGER_HOST} localhost
# CLIENT_WEB_URL / TS_EXTERNAL_* / WK_EXTERNAL_* 由 docker-compose 根据 PUBLIC_* 自动生成

TS_API_PORT=8090
WK_TCP_PORT=5100
WK_WS_PORT=5200
WK_WEB_SERVER_PORT=5300

# MySQL
MYSQL_ROOT_PASSWORD=change-me-mysql-password
MYSQL_DATABASE=im

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-minio-password

# 文件服务
TS_FILESERVICE=minio

# Server 运行配置（排查 H5 登录时可改为 debug；稳定后可改回 release）
TS_MODE=debug
# 日志级别：1=debug（对应 zap -1），2=info；0 表示跟随 mode
TS_LOGGER_LEVEL=1
TS_LOGGER_LINENUM=true
TS_WUKONGIM_APIURL=http://wukongim:5001
TS_DB_REDISADDR=redis:6379
# 注册接口：JSON 里 `code` 是短信验证码（本仓库 Android/iOS 隐藏短信框时固定传 123456），
# `invite_code` 才是邀请码；二者不是同一个字段。TS_SMSCODE 必须与 App 传的 `code` 一致。
TS_SMSCODE=123456
TS_ADMINPWD=change-me-admin-password
TS_MINIO_UPLOADURL=http://minio:9000
# TS_MINIO_DOWNLOADURL 由 docker-compose 根据 PUBLIC_* 自动生成

# WuKongIM 运行配置
WK_MODE=release
WK_CONVERSATION_ON=true
WK_WEBHOOK_GRPCADDR=server:6979
WK_DATASOURCE_ADDR=http://server:8090/v1/datasource
WK_DATASOURCE_CHANNELINFOON=true
WK_TOKENAUTHON=true
WK_WHITELISTOFFOFPERSON=false
WK_JWT_SECRET=change-me-wukongim-jwt-secret
# WK_EXTERNAL_TCPADDR / WK_EXTERNAL_WSADDR / WK_EXTERNAL_WSSADDR 由 docker-compose 根据 PUBLIC_* 自动生成

# 头像默认来源：未上传头像时使用（避免 MinIO 默认 avatar 未预置导致 404）
TS_AVATAR_DEFAULTBASEURL=https://api.dicebear.com/8.x/avataaars/png?seed={avatar}&size=180
