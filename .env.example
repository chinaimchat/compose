# 基础配置
CONTAINER_NAME=my
# 服务器公网主 IP（用于 IM 对外地址上报）
EXTERNAL_IP=EXTERNAL_IP

# 端口（官方默认）
TS_WEB_PORT=82
TS_MANAGEMENT_PORT=83
# 容器内 web/manager 反代到后端的内部地址（一般无需改）
INTERNAL_API_URL=http://server:8090/
# 容器内 Nginx 的 server_name（迁移时按你的域名改）
WEB_SERVER_NAME=web.***.*** www.***.*** ***.*** localhost
MANAGER_SERVER_NAME=houtai.***.*** localhost
# 用户端 Web 对外根地址（HTTP）
CLIENT_WEB_URL=http://www.***.***

# 后端对外 BaseURL（用户/群/扫码登录 二维码、邀请链接等都基于它拼）。
# - 必须是「外部能访问 + 反代会进 server」的根地址；带不带 `/api` 取决于反代规则。
# - 当前 web 容器内 nginx 把 `/api/` 反代到 `server:8090/`，因此这里写 `…/api`，
#   server 内拼出的 APIBaseURL 即 `…/api/v1`，二维码 URL 形如 `…/api/v1/qrcode/<uuid>`，
#   与浏览器看到的路径一致，避免对外暴露内网 IP+8090。
# - 如果切回宿主机 nginx 直接反代 `/v1/`，把这里改成 `http://web.***.***` 即可。
TS_EXTERNAL_BASEURL=http://web.***.***/api
# 可选：若 H5 域名与上面不同（邀请链接、扫群转 H5 等会用到），单独覆盖；不写默认走 BaseURL。
# TS_EXTERNAL_H5BASEURL=http://web.***.***

TS_API_PORT=8090
WK_TCP_PORT=5100
WK_WS_PORT=5200
WK_WEB_SERVER_PORT=5300

# MySQL
MYSQL_ROOT_PASSWORD=Chy@2026Mysql
MYSQL_DATABASE=im

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=Chy@2026Minio

# 文件服务
TS_FILESERVICE=minio

# Server 运行配置（排查 H5 登录时可改为 debug；稳定后可改回 release）
TS_MODE=debug
# 日志级别：1=debug（对应 zap -1），2=info；0 表示跟随 mode
TS_LOGGER_LEVEL=1
TS_LOGGER_LINENUM=true
TS_WUKONGIM_APIURL=http://wukongim:5001
TS_DB_REDISADDR=redis:6379
# 注册接口：JSON 里 `code` 是短信验证码（本仓库 Android/iOS 隐藏短信框时固定传 123456），
# `invite_code` 才是邀请码；二者不是同一个字段。TS_SMSCODE 必须与 App 传的 `code` 一致。
# 若写成 **** 等占位符，会覆盖镜像内 tsdd.yaml 的 smsCode，导致一直报「验证码错误」。
TS_SMSCODE=123456
TS_ADMINPWD=admin1234567
TS_MINIO_UPLOADURL=http://minio:9000
TS_MINIO_DOWNLOADURL=http://***.***.***.***:9000

# WuKongIM 运行配置
WK_MODE=release
WK_CONVERSATION_ON=true
WK_WEBHOOK_GRPCADDR=server:6979
WK_DATASOURCE_ADDR=http://server:8090/v1/datasource
WK_DATASOURCE_CHANNELINFOON=true
WK_TOKENAUTHON=true
WK_WHITELISTOFFOFPERSON=false
WK_JWT_SECRET=wk_secret_123

# 头像默认来源：未上传头像时使用（避免 MinIO 默认 avatar 未预置导致 404）
TS_AVATAR_DEFAULTBASEURL=https://api.dicebear.com/8.x/avataaars/png?seed={avatar}&size=180
