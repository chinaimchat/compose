# =============================================================================
# Docker Compose 环境变量（可提交到 Git 的示例）
# -----------------------------------------------------------------------------
# 说明：
# 1. 本文件内「密码、密钥、验证码」等敏感项已用 * 脱敏，仅作格式参考。
# 2. 部署到真实环境时，请复制本文件为同名 .env 后，把占位符改成自己的强密码。
# 3. 切勿把含真实密码的 .env 推送到公开仓库；本地可用 .env.private 备份（勿提交）。
# =============================================================================

# -----------------------------------------------------------------------------
# 基础 / 网络
# -----------------------------------------------------------------------------
# 容器命名前缀（可选，部分脚本会用到）
CONTAINER_NAME=my

# 对外公网 IP 或域名（客户端、MinIO 下载链接、管理后台「以此用户视角」默认用户端地址等会引用）
# 示例文档网段（请改为你的公网 IP 或域名）：https://datatracker.ietf.org/doc/html/rfc5737
EXTERNAL_IP=203.0.113.10

# -----------------------------------------------------------------------------
# 对外端口映射（宿主机端口 : 容器内端口 在 docker-compose.yaml 中配置）
# -----------------------------------------------------------------------------
# 用户端 Web（chinaim-web 容器 nginx 80）
TS_WEB_PORT=82
# 管理后台（chinaim-manager 容器 nginx 80）
TS_MANAGEMENT_PORT=83
# 业务 API（chinaim-server）
TS_API_PORT=8090
# 悟空 IM：TCP / WebSocket / 内置监控页
WK_TCP_PORT=5100
WK_WS_PORT=5200
WK_WEB_SERVER_PORT=5300

# 用户端 Web 根地址（可选）。
# 不设时：compose 里 manager 服务会用 http://${EXTERNAL_IP}:${TS_WEB_PORT} 作为默认 CLIENT_WEB_URL，
# 供管理后台「以此用户视角查看」弹窗内 iframe 加载用户端。
# 若用户端走 HTTPS 或独立域名，在此显式指定，例如：
# CLIENT_WEB_URL=https://im.example.com
# CLIENT_WEB_URL=

# -----------------------------------------------------------------------------
# MySQL（mysql 服务）
# -----------------------------------------------------------------------------
# root 密码（须与 TS_DB_MYSQLADDR 中 server 使用的变量一致）
MYSQL_ROOT_PASSWORD=****************
# 业务库名
MYSQL_DATABASE=im

# -----------------------------------------------------------------------------
# MinIO（minio 服务，对象存储）
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=****************

# -----------------------------------------------------------------------------
# 唐僧叨叨 Server（server 服务，读取 env_file: .env）
# -----------------------------------------------------------------------------
# 运行模式：release / debug 等，视镜像约定
TS_MODE=release
# 文件存储后端：minio 等
TS_FILESERVICE=minio

# 悟空 IM 管理/业务 HTTP API（容器内网，一般为 wukongim:5001）
TS_WUKONGIM_APIURL=http://wukongim:5001

# Redis 地址（容器内网）
TS_DB_REDISADDR=redis:6379

# 短信/验证码占位（开发或内网环境常用固定码；生产请接入真实短信并改掉）
TS_SMSCODE=******

# 超级管理员初始密码（仅首次初始化等场景使用，务必改为强密码）
TS_ADMINPWD=****************

# MinIO 上传/下载地址：
# 上传一般为容器内网；下载若给客户端浏览器用，需为「浏览器可访问」的公网 URL（常含 EXTERNAL_IP 与 9000 端口）
TS_MINIO_UPLOADURL=http://minio:9000
# 须与 EXTERNAL_IP 对浏览器可达方式一致（端口为 MinIO API 映射宿主机端口，默认 9000）
TS_MINIO_DOWNLOADURL=http://203.0.113.10:9000

# -----------------------------------------------------------------------------
# 悟空 IM（wukongim 服务）
# -----------------------------------------------------------------------------
WK_MODE=release
WK_CONVERSATION_ON=true
WK_WEBHOOK_GRPCADDR=server:6979
WK_DATASOURCE_ADDR=http://server:8090/v1/datasource
WK_DATASOURCE_CHANNELINFOON=true
WK_TOKENAUTHON=true
WK_WHITELISTOFFOFPERSON=false

# IM JWT 密钥（须与 server 侧配置一致；生产请使用足够长的随机串）
WK_JWT_SECRET=********************************
